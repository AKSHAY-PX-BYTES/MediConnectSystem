# ─────────────────────────────────────────────────────────────────────────────
# MediConnect — environment variable reference
# Copy relevant values into your hosting provider's dashboard (Render, Railway,
# Fly.io, etc.). Do NOT commit real secrets to git.
# ASP.NET Core maps the "__" (double underscore) to nested config keys.
# ─────────────────────────────────────────────────────────────────────────────

# ---- Backend (ASP.NET Core API) ----

ASPNETCORE_ENVIRONMENT=Production

# Neon / PostgreSQL connection string (Default connection)
ConnectionStrings__Default=Host=ep-xxx-pooler.region.aws.neon.tech;Port=5432;Database=mediconnect;Username=mediconnect_owner;Password=YOUR_PASSWORD;SSL Mode=Require;Trust Server Certificate=true

# JWT — use a long random string (>= 32 chars). Generate one with:
#   openssl rand -base64 48
Jwt__Secret=CHANGE_ME_to_a_long_random_secret_at_least_32_chars
Jwt__Issuer=MediConnect
Jwt__Audience=MediConnectClients
Jwt__AccessTokenMinutes=60
Jwt__RefreshTokenDays=7

# Allowed CORS origins (the deployed frontend URL). Indexed for array binding.
# Only needed if the frontend calls the API cross-origin (i.e. you are NOT using
# the Netlify/Vercel /api proxy rewrite).
Cors__Origins__0=https://your-frontend.netlify.app

# Some hosts (Render/Railway/Fly) inject PORT automatically; the app honors it.
# PORT=8080

# ---- Frontend (build-time) ----
# The Angular app reads its API base URL from src/environments/environment.prod.ts.
# Default is "/api" which works with the Netlify/Vercel proxy rewrite.
# If you instead call the backend directly, set it to the full URL, e.g.:
#   apiUrl: 'https://mediconnect-api.onrender.com/api'
